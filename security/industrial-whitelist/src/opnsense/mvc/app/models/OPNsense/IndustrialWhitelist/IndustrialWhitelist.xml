<model>
    <mount>//OPNsense/IndustrialWhitelist</mount>
    <description>Industrial protocol whitelist</description>
    <items>
        <general>
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>
            <default_action type="OptionField">
                <Required>Y</Required>
                <Default>log_only</Default>
                <OptionValues>
                    <block>Block</block>
                    <log_only>Log Only</log_only>
                </OptionValues>
            </default_action>
        </general>
        <rules>
            <rule type="ArrayField">
                <enabled type="BooleanField">
                    <Default>1</Default>
                    <Required>Y</Required>
                </enabled>
                <sequence type="AutoNumberField">
                    <MinimumValue>1</MinimumValue>
                    <MaximumValue>99999</MaximumValue>
                </sequence>
                <source type="TextField">
                    <Required>Y</Required>
                    <Default>any</Default>
                    <Mask>/^([A-Za-z0-9_\-\.:\/]+|any)$/</Mask>
                    <ValidationMessage>Use IP/CIDR/Alias or "any".</ValidationMessage>
                </source>
                <destination type="TextField">
                    <Required>Y</Required>
                    <Default>any</Default>
                    <Mask>/^([A-Za-z0-9_\-\.:\/]+|any)$/</Mask>
                    <ValidationMessage>Use IP/CIDR/Alias or "any".</ValidationMessage>
                </destination>
                <protocol type="OptionField">
                    <Required>Y</Required>
                    <Default>modbus_tcp</Default>
                    <OptionValues>
                        <modbus_tcp>Modbus TCP (Port 502)</modbus_tcp>
                        <s7comm>S7Comm (Port 102)</s7comm>
                        <eip>EtherNet/IP (TCP/UDP 44818, UDP 2222)</eip>
                        <iec104>IEC 60870-5-104 (TCP 2404)</iec104>
                        <dnp3>DNP3 (TCP/UDP 20000)</dnp3>
                        <mqtt>MQTT (TCP 1883/8883)</mqtt>
                        <bacnet>BACnet (UDP 47808)</bacnet>
                    </OptionValues>
                </protocol>
                <AllowedFunctionCodes type="OptionField">
                    <Multiple>Y</Multiple>
                    <OptionValues>
                        <read_only>Read Operations</read_only>
                        <write_single>Write Operations (Single)</write_single>
                        <write_multiple>Write Operations (Multiple/Bulk)</write_multiple>
                        <diagnostic>Diagnostic / Session Operations</diagnostic>
                    </OptionValues>
                </AllowedFunctionCodes>
                <StrictDPI type="BooleanField">
                    <Default>0</Default>
                    <help>开启后，系统将严格校验应用层载荷。任何尝试通过此端口传输的非标或伪造协议（如 SSH/HTTP 伪装成 Modbus）将被直接丢弃（Drop）。关闭则仅告警（Alert）。</help>
                </StrictDPI>
                <description type="DescriptionField"/>
            </rule>
        </rules>
    </items>
</model>
