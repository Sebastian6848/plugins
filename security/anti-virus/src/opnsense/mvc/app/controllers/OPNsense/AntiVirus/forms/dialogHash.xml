<form>
    <field>
        <id>entry.enabled</id>
        <label>Enabled</label>
        <type>checkbox</type>
        <help>Enable this whitelist hash entry.</help>
        <grid_view>
            <width>6em</width>
            <type>boolean</type>
            <formatter>rowtoggle</formatter>
        </grid_view>
    </field>
    <field>
        <id>entry.sha256</id>
        <label>SHA256</label>
        <type>text</type>
        <help>64-character SHA256 digest.</help>
    </field>
    <field>
        <id>entry.description</id>
        <label>Description</label>
        <type>text</type>
        <help>Optional note.</help>
    </field>
</form>