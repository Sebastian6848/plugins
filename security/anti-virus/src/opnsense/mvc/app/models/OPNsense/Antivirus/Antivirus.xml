<model>
    <mount>//OPNsense/antivirus</mount>
    <description>Antivirus configuration</description>
    <version>1.0.0</version>
    <items>
        <enabled type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </enabled>
        <mode type="OptionField">
            <Default>explicit_proxy</Default>
            <Required>Y</Required>
            <OptionValues>
                <explicit_proxy>Explicit proxy</explicit_proxy>
                <transparent_proxy>Transparent proxy</transparent_proxy>
                <disabled>Disabled</disabled>
            </OptionValues>
        </mode>
        <scan_http type="BooleanField">
            <Default>1</Default>
            <Required>Y</Required>
        </scan_http>
        <scan_https type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </scan_https>
        <max_scan_size_mb type="IntegerField">
            <Default>50</Default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>1024</MaximumValue>
            <Required>Y</Required>
        </max_scan_size_mb>
        <oversize_action type="OptionField">
            <Default>bypass_and_log</Default>
            <Required>Y</Required>
            <OptionValues>
                <bypass_and_log>Bypass and log</bypass_and_log>
                <block_and_log>Block and log</block_and_log>
            </OptionValues>
        </oversize_action>
        <bypass_on_failure type="BooleanField">
            <Default>1</Default>
            <Required>Y</Required>
        </bypass_on_failure>
        <scan_archives type="BooleanField">
            <Default>1</Default>
            <Required>Y</Required>
        </scan_archives>
        <scan_filetypes type="OptionField">
            <Default>TEXT,DATA,EXECUTABLE,ARCHIVE,GIF,JPEG,MSOFFICE</Default>
            <Multiple>Y</Multiple>
            <Required>Y</Required>
            <OptionValues>
                <TEXT>Text files</TEXT>
                <DATA>Binary files</DATA>
                <EXECUTABLE>Executables</EXECUTABLE>
                <ARCHIVE>Archives</ARCHIVE>
                <GIF>GIF images</GIF>
                <JPEG>JPEG images</JPEG>
                <MSOFFICE>Microsoft Office files</MSOFFICE>
            </OptionValues>
        </scan_filetypes>
        <whitelist_domains type="CSVListField"/>
        <whitelist_client_ips type="CSVListField"/>
        <whitelist_mime_types type="CSVListField"/>
        <freshclam_interval_hours type="IntegerField">
            <Default>12</Default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>24</MaximumValue>
            <Required>Y</Required>
        </freshclam_interval_hours>
        <log_retention_days type="IntegerField">
            <Default>90</Default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>3650</MaximumValue>
            <Required>Y</Required>
        </log_retention_days>
        <alert_threshold_per_ip_1h type="IntegerField">
            <Default>5</Default>
            <MinimumValue>1</MinimumValue>
            <MaximumValue>10000</MaximumValue>
            <Required>Y</Required>
        </alert_threshold_per_ip_1h>
    </items>
</model>
