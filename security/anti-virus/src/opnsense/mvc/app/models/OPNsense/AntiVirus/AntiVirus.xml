<model>
    <mount>//OPNsense/antivirus</mount>
    <description>Industrial sidecar antivirus settings</description>
    <version>1.0.0</version>
    <items>
        <general>
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>
            <extract_dir type="TextField">
                <Required>Y</Required>
                <Default>/var/run/av_extract</Default>
            </extract_dir>
            <max_file_size_mb type="IntegerField">
                <Required>Y</Required>
                <Default>10</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>50</MaximumValue>
            </max_file_size_mb>
            <queue_size type="IntegerField">
                <Required>Y</Required>
                <Default>50</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>1000</MaximumValue>
            </queue_size>
            <worker_threads type="IntegerField">
                <Required>Y</Required>
                <Default>4</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>64</MaximumValue>
            </worker_threads>
            <cache_ttl_seconds type="IntegerField">
                <Required>Y</Required>
                <Default>86400</Default>
                <MinimumValue>60</MinimumValue>
                <MaximumValue>2592000</MaximumValue>
            </cache_ttl_seconds>
            <block_duration_seconds type="IntegerField">
                <Required>Y</Required>
                <Default>3600</Default>
                <MinimumValue>60</MinimumValue>
                <MaximumValue>2592000</MaximumValue>
            </block_duration_seconds>
            <block_table type="TextField">
                <Required>Y</Required>
                <Default>industrial_av_block</Default>
                <Mask>/^[A-Za-z0-9_\-]+$/</Mask>
                <ValidationMessage>PF table name only accepts letters, digits, underscore and dash.</ValidationMessage>
            </block_table>
            <scan_http type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </scan_http>
            <scan_ftp type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </scan_ftp>
            <scan_smb type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </scan_smb>
            <enforce_tls_baseline type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </enforce_tls_baseline>
            <extensions type="TextField">
                <Required>Y</Required>
                <Default>exe,dll,elf,sh,bin</Default>
            </extensions>
            <clamd_socket type="TextField">
                <Required>Y</Required>
                <Default>/var/run/clamav/clamd.sock</Default>
            </clamd_socket>
        </general>
        <whitelist>
            <entry type="ArrayField">
                <enabled type="BooleanField">
                    <Default>1</Default>
                    <Required>Y</Required>
                </enabled>
                <sha256 type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[A-Fa-f0-9]{64}$/</Mask>
                    <ValidationMessage>SHA256 must be 64 hex characters.</ValidationMessage>
                </sha256>
                <description type="DescriptionField"/>
            </entry>
        </whitelist>
    </items>
</model>