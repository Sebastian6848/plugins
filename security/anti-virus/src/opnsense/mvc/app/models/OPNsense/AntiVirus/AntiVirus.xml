<model>
    <mount>//OPNsense/antivirus</mount>
    <description>Industrial sidecar antivirus settings</description>
    <version>1.0.0</version>
    <items>
        <general>
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>
            <enable_yara type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enable_yara>
            <max_file_size_mb type="IntegerField">
                <Required>Y</Required>
                <Default>10</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>50</MaximumValue>
            </max_file_size_mb>
            <queue_size type="IntegerField">
                <Required>Y</Required>
                <Default>50</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>1000</MaximumValue>
            </queue_size>
            <worker_threads type="IntegerField">
                <Required>Y</Required>
                <Default>4</Default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>64</MaximumValue>
            </worker_threads>
            <cache_ttl_seconds type="IntegerField">
                <Required>Y</Required>
                <Default>86400</Default>
                <MinimumValue>60</MinimumValue>
                <MaximumValue>2592000</MaximumValue>
            </cache_ttl_seconds>
            <block_duration_seconds type="IntegerField">
                <Required>Y</Required>
                <Default>3600</Default>
                <MinimumValue>60</MinimumValue>
                <MaximumValue>2592000</MaximumValue>
            </block_duration_seconds>
            <response_mode type="OptionField">
                <Required>Y</Required>
                <Default>block_ip</Default>
                <OptionValues>
                    <block_ip>Block source IP</block_ip>
                    <alert_only>Alert only</alert_only>
                    <drop_only>Drop sample only</drop_only>
                </OptionValues>
            </response_mode>
            <monitored_protocols type="OptionField">
                <Required>Y</Required>
                <Multiple>Y</Multiple>
                <Default>http,ftp,smb</Default>
                <OptionValues>
                    <http>HTTP</http>
                    <ftp>FTP</ftp>
                    <smb>SMB</smb>
                </OptionValues>
            </monitored_protocols>
            <extensions type="TextField">
                <Required>Y</Required>
                <Default>exe,dll,elf,sh,bin</Default>
            </extensions>
        </general>
        <whitelist>
            <entry type="ArrayField">
                <enabled type="BooleanField">
                    <Default>1</Default>
                    <Required>Y</Required>
                </enabled>
                <sha256 type="TextField">
                    <Required>Y</Required>
                    <Mask>/^[A-Fa-f0-9]{64}$/</Mask>
                    <ValidationMessage>SHA256 must be 64 hex characters.</ValidationMessage>
                </sha256>
                <description type="DescriptionField"/>
            </entry>
        </whitelist>
    </items>
</model>