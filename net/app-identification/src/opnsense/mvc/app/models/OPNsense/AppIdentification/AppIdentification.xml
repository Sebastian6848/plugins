<model>
	<mount>//OPNsense/AppIdentification/general</mount>
	<description>AppIdentification ntopng configuration</description>
	<version>1.0.0</version>
	<items>
		<enabled type="BooleanField">
			<Default>0</Default>
			<Required>Y</Required>
		</enabled>
		<interfaces type="InterfaceField">
			<Required>N</Required>
			<Multiple>Y</Multiple>
			<AllowDynamic>Y</AllowDynamic>
		</interfaces>
		<rest_scheme type="OptionField">
			<Required>N</Required>
			<Default>http</Default>
			<OptionValues>
				<Option0 value="http">HTTP</Option0>
				<Option1 value="https">HTTPS</Option1>
			</OptionValues>
		</rest_scheme>
		<rest_host type="TextField">
			<Required>N</Required>
			<Default>127.0.0.1</Default>
		</rest_host>
		<rest_port type="PortField">
			<Required>Y</Required>
			<Default>3000</Default>
		</rest_port>
		<ifid type="IntegerField">
			<Required>N</Required>
			<Default>0</Default>
			<MinimumValue>0</MinimumValue>
		</ifid>
		<auth_mode type="OptionField">
			<Required>N</Required>
			<Default>none</Default>
			<OptionValues>
				<Option0 value="none">None</Option0>
				<Option1 value="basic">Basic</Option1>
				<Option2 value="token">Token</Option2>
				<Option3 value="cookie">Cookie</Option3>
			</OptionValues>
		</auth_mode>
		<auth_username type="TextField">
			<Required>N</Required>
			<Default>admin</Default>
		</auth_username>
		<auth_password type="TextField">
			<Required>N</Required>
		</auth_password>
		<auth_token type="TextField">
			<Required>N</Required>
		</auth_token>
		<auth_cookie type="TextField">
			<Required>N</Required>
		</auth_cookie>
		<http_port type="PortField">
			<Required>Y</Required>
			<Default>3000</Default>
		</http_port>
		<https_port type="PortField">
			<Required>N</Required>
			<Constraints>
				<check001>
					<ValidationMessage>Please select a HTTPS port and a valid certificate</ValidationMessage>
					<type>AllOrNoneConstraint</type>
					<addFields>
						<field1>certificate</field1>
					</addFields>
				</check001>
			</Constraints>
		</https_port>
		<dns_mode type="OptionField">
			<Required>N</Required>
			<Default>0</Default>
			<OptionValues>
				<Option0 value="0">Decode DNS responses and resolve only local numeric IPs</Option0>
				<Option1 value="1">Decode DNS responses and resolve all numeric IPs</Option1>
				<Option2 value="2">Decode DNS responses and do not resolve numeric IPs</Option2>
				<Option3 value="3">Do not decode DNS responses and do not resolve numeric IPs</Option3>
			</OptionValues>
		</dns_mode>
		<certificate type="CertificateField">
			<Type>cert</Type>
			<Required>N</Required>
			<Constraints>
				<check001>
					<reference>https_port.check001</reference>
				</check001>
			</Constraints>
		</certificate>
		<max_flows type="IntegerField">
			<Required>N</Required>
			<Default>200000</Default>
			<MinimumValue>10000</MinimumValue>
			<MaximumValue>10000000</MaximumValue>
		</max_flows>
		<max_hosts type="IntegerField">
			<Required>N</Required>
			<Default>100000</Default>
			<MinimumValue>1000</MinimumValue>
			<MaximumValue>5000000</MaximumValue>
		</max_hosts>
		<local_networks type="TextField">
			<Required>N</Required>
		</local_networks>
		<extra_options type="TextField">
			<Required>N</Required>
		</extra_options>
		<rules>
			<rule type="ArrayField">
				<enabled type="BooleanField">
					<Default>1</Default>
					<Required>Y</Required>
				</enabled>
				<description type="TextField">
					<Required>N</Required>
				</description>
				<match_type type="OptionField">
					<Required>Y</Required>
					<Default>domain</Default>
					<OptionValues>
						<domain value="domain">Domain substring</domain>
						<ip value="ip">Exact IP</ip>
						<cidr value="cidr">CIDR network</cidr>
						<port value="port">Destination port</port>
						<protocol value="protocol">Protocol name</protocol>
					</OptionValues>
				</match_type>
				<match_value type="TextField">
					<Required>Y</Required>
				</match_value>
				<app_label type="TextField">
					<Required>Y</Required>
				</app_label>
			</rule>
		</rules>
	</items>
</model>
